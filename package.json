{
  "name": "hatch-ts-space-la-biblioth-que",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "typecheck": "bun x tsc --noEmit -p client/tsconfig.json && bun x tsc --noEmit -p server/tsconfig.json",
    "build": "bun run build:server && bun run build:client",
    "build:server": "bun build ./server/src/actions.ts --target=bun --outfile=./server/dist/actions.js",
    "build:client": "bun ./client/build.mjs"
  },
  "dependencies": {
    "@hatch/space-sdk": "file:/home/hatch/skills/spaces/ts-runtime/dist/space-sdk.tgz",
    "@tanstack/react-query": "5.100.10",
    "drizzle-orm": "0.44.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.1.13",
    "tailwindcss-safe-area": "1.3.0",
    "typescript": "5.6.3"
  }
}
